NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Canonical production URL used to build auth email redirect links
# (confirmation, invite, password reset). Without this, the app falls back to
# deriving it from the request's Host header, which usually works but is not
# guaranteed behind every proxy/CDN setup — set this explicitly in production.
# Must also be added to Supabase Dashboard -> Authentication -> URL
# Configuration -> Site URL / Redirect URLs, or Supabase will silently ignore
# it and fall back to its own configured Site URL.
NEXT_PUBLIC_SITE_URL=https://www.royalinventra.com.ng

# Paystack — subscription billing. Secret key is used both for API calls
# (lib/paystack.ts) and to verify webhook signatures
# (app/api/webhooks/paystack/route.ts). Plan codes come from creating the
# Monthly and Yearly plans once via the Paystack dashboard or the POST /plan
# API (see createPlan() in lib/paystack.ts) — the amount is baked into the
# Plan object at creation time, so it MUST match
# NEXT_PUBLIC_PLAN_PRICE_MONTHLY/YEARLY below or Paystack's own recurring
# auto-charges will silently use a different amount than what the app
# displays/charges on demand.
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_CODE_MONTHLY=
PAYSTACK_PLAN_CODE_YEARLY=

# Displayed price and the amount used for on-demand charges (e.g.
# reactivateSubscription). Naira, whole numbers. Change PAYSTACK_PLAN_CODE_*
# above to match (new Paystack Plan at the new amount) whenever these change.
NEXT_PUBLIC_PLAN_PRICE_MONTHLY=5000
NEXT_PUBLIC_PLAN_PRICE_YEARLY=50000

# Resend — transactional billing emails (lib/email.ts). Sending is skipped
# (logged only) if RESEND_API_KEY is unset, so this can be left blank in
# local dev without breaking the billing flow.
RESEND_API_KEY=
RESEND_FROM_EMAIL=billing@yourdomain.com

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# invoking app/api/cron/billing-sweep — set the same value in Vercel's
# project env vars (Vercel adds this header automatically once CRON_SECRET
# is configured there).
CRON_SECRET=

# Comma-separated allowlist of emails allowed to view /admin (platform-wide
# subscription dashboard across every org). Anyone else hitting that route
# is redirected to /dashboard — see requirePlatformAdmin() in
# lib/queries/session.ts.
PLATFORM_ADMIN_EMAILS=
