NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Canonical production URL used to build auth email redirect links
# (confirmation, invite, password reset). Without this, the app falls back to
# deriving it from the request's Host header, which usually works but is not
# guaranteed behind every proxy/CDN setup — set this explicitly in production.
# Must also be added to Supabase Dashboard -> Authentication -> URL
# Configuration -> Site URL / Redirect URLs, or Supabase will silently ignore
# it and fall back to its own configured Site URL.
NEXT_PUBLIC_SITE_URL=https://royal-inventra.vercel.app

# Paystack — subscription billing. Secret key is used both for API calls
# (lib/paystack.ts) and to verify webhook signatures
# (app/api/webhooks/paystack/route.ts). Plan codes come from creating the
# Monthly (₦1,500) and Yearly (₦15,000) plans once via the Paystack
# dashboard or the POST /plan API (see createPlan() in lib/paystack.ts).
PAYSTACK_SECRET_KEY=sk_test_a81c2fc3ea7e2d39ab49df50e4543fdb920e7b1f
PAYSTACK_PLAN_CODE_MONTHLY=PLN_471seldr1kuglm2
PAYSTACK_PLAN_CODE_YEARLY=PLN_wj3j50tyj0byfvs

# Resend — transactional billing emails (lib/email.ts). Sending is skipped
# (logged only) if RESEND_API_KEY is unset, so this can be left blank in
# local dev without breaking the billing flow.
RESEND_API_KEY=re_fhrWz7Fp_E9JRWyVkSaUhqmoCUvuS3Qaf
RESEND_FROM_EMAIL=billing@yourdomain.com

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# invoking app/api/cron/billing-sweep — set the same value in Vercel's
# project env vars (Vercel adds this header automatically once CRON_SECRET
# is configured there).
CRON_SECRET=
